PAPER_MODE=true
DB_PATH=data/bot.db
STARTING_BANKROLL=100.0

# Strategy Thresholds
EDGE_THRESHOLD=0.08
MIN_MODEL_AGREEMENT=0.6
# 2.7°F = 1.5°C — maximum spread between model forecasts before trade is skipped
MAX_MODEL_SPREAD=2.7

# Base forecast uncertainty in °F by lead time (interpolated)
BASE_FORECAST_ERROR_12H=1.0
BASE_FORECAST_ERROR_24H=1.5
BASE_FORECAST_ERROR_48H=2.0
BASE_FORECAST_ERROR_72H=2.5

# Risk / Sizing (Micro-account)
DAILY_LOSS_LIMIT=-5.00
HARD_MAX_POSITION_SIZE=2.0
MAX_POSITION_FRACTION=0.10
MAX_TOTAL_EXPOSURE_FRACTION=0.30
MAX_CONCURRENT_POSITIONS=3
BASE_POSITION_FRACTION=0.05
KELLY_CAP=0.08
MIN_POSITION_SIZE=0.50

STOP_LOSS_PCT=0.15
EXIT_EDGE_FLOOR=0.05

# Market Filters
MIN_VOLUME=10000
MAX_HOURS_TO_RESOLUTION=72

# Market Discovery
# Markets per API page (Gamma API max is 100)
MARKET_DISCOVERY_LIMIT=100
# Maximum pages to fetch per scan cycle (100 markets each)
MARKET_DISCOVERY_MAX_PAGES=10
# Stop fetching new pages once this many weather candidates are found
MARKET_DISCOVERY_STOP_AFTER_WEATHER=50

# Debugging
# Show accepted weather markets detail
DEBUG_MARKET_SCAN=false
# Show all skipped markets detail (verbose)
DEBUG_MARKET_SCAN_VERBOSE=false
# Print discovered weather markets and exit without trading (useful for manual checks)
DEBUG_WEATHER_DISCOVERY=false

# Scheduling (minutes)
SCAN_INTERVAL_MINUTES=10
MONITOR_INTERVAL_MINUTES=5

# Polymarket credentials (only needed for live trading)
POLYMARKET_PK=your_private_key_here
CLOB_API_KEY=your_clob_api_key
CLOB_SECRET=your_clob_secret
CLOB_PASS_PHRASE=your_clob_passphrase

