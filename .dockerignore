# Virtual environments — the image runs its own `pip install`, never ship these
.venv
venv
env

# Python caches
__pycache__
*.pyc
*.pyo
*.pyd
.pytest_cache
.mypy_cache

# Local database & runtime data — the Fly volume provides /data
data
*.db
*.db-wal
*.db-shm
*.sqlite

# Version control
.git
.gitignore

# Secrets — never bake into the image; use `fly secrets`
.env

# Tests aren't needed at runtime
tests

# Editor / OS noise
.vscode
.idea
.DS_Store

# Docs
*.md
